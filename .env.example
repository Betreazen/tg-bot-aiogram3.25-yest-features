# Post Styling Demo Bot Configuration
# Copy this file to .env and fill in your values

# Required: Your Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Optional: Enable custom emoji features (requires Telegram Premium or Fragment usernames)
# Set to false if you don't have Premium or want to test fallback mode
CUSTOM_EMOJI_ENABLED=true

# Optional: Enable automatic fallback to Unicode emoji when custom emoji unavailable
FALLBACK_ENABLED=true
